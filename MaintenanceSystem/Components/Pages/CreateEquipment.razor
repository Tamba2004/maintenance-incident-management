@page "/create-equipment"
@inject EquipmentService EquipmentService
@using MaintenanceSystem.Models
@using MaintenanceSystem.Services

<PageTitle>Nouvel équipement</PageTitle>

<h3>Ajouter un équipement</h3>

@if (succès)
{
    <div class="alert alert-success">
        L'équipement a été ajouté avec succès.
    </div>
}

<EditForm Model="@equipment"
          OnValidSubmit="HandleSubmit"
          FormName="CreateEquipmentForm">

    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Nom</label>
        <InputText class="form-control" @bind-Value="equipment.Name" />
        <ValidationMessage For="@(() => equipment.Name)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Localisation</label>
        <InputText class="form-control" @bind-Value="equipment.Location" />
    </div>

    <div class="mb-3">
        <label class="form-label">Catégorie</label>
        <InputText class="form-control" @bind-Value="equipment.Category" />
    </div>

    <button type="submit" class="btn btn-primary">
        Ajouter
    </button>

</EditForm>

@code {
    private Equipment equipment = new();
    private bool succès = false;

    private async Task HandleSubmit()
    {
        await EquipmentService.CreateEquipmentAsync(equipment);
        succès = true;
        equipment = new();
    }
}